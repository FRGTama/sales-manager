# Supabase PostgreSQL connection strings
# Use Session pooler URI if Direct connection is giving errors.
# Replace placeholders with your actual Supabase project details

DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Separate database for tests (create via Supabase SQL Editor: CREATE DATABASE sharework_test;)
TEST_DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/sharework_test

# Cloudflare Tunnel token (for production deployment only)
# Create a tunnel at https://one.dash.cloudflare.com -> Networks -> Tunnels
# Then add it to your EC2 .env file
CLOUDFLARE_TUNNEL_TOKEN=
